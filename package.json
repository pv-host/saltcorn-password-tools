{
  "name": "saltcorn-password-tools",
  "version": "0.3.3",
  "description": "Saltcorn plugin: hash plaintext passwords (BLF-CRYPT / SHA512-CRYPT / PBKDF2) with configurable Dovecot-compatible prefix and integrated password-strength meter (zxcvbn + rule checks).",
